 <!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Smart Object Alert</title>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Pretendard', sans-serif;
    }

    body {
      background: linear-gradient(135deg, #eef4ff, #dce9ff);
      height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .container {
      width: 380px;
      background: white;
      border-radius: 28px;
      padding: 30px;
      box-shadow: 0 15px 40px rgba(0,0,0,0.12);
    }

    .title {
      font-size: 30px;
      font-weight: 800;
      color: #1f4fff;
      margin-bottom: 10px;
    }

    .subtitle {
      color: #666;
      font-size: 15px;
      margin-bottom: 30px;
      line-height: 1.5;
    }

    .status-box {
      background: #f4f7ff;
      border-radius: 20px;
      padding: 25px;
      margin-bottom: 25px;
      text-align: center;
    }

    .distance {
      font-size: 50px;
      font-weight: 800;
      color: #1f4fff;
      margin-bottom: 10px;
    }

    .object-name {
      font-size: 22px;
      font-weight: 700;
      color: #222;
    }

    .message {
      margin-top: 12px;
      color: #555;
      line-height: 1.5;
    }

    .btn {
      width: 100%;
      padding: 16px;
      border: none;
      border-radius: 18px;
      font-size: 18px;
      font-weight: 700;
      cursor: pointer;
      transition: 0.2s;
      margin-bottom: 15px;
    }

    .connect-btn {
      background: #1f4fff;
      color: white;
    }

    .connect-btn:hover {
      transform: scale(1.02);
    }

    .start-btn {
      background: #00c27a;
      color: white;
    }

    .start-btn:hover {
      transform: scale(1.02);
    }

    .footer {
      margin-top: 15px;
      text-align: center;
      color: #888;
      font-size: 13px;
    }
  </style>
</head>
<body>

  <div class="container">

    <div class="title">Smart Alert</div>

    <div class="subtitle">
      아두이노 센서와 연동하여  
      물체 감지 시 음성으로 안내합니다.
    </div>

    <div class="status-box">
      <div class="distance" id="distance">0m</div>
      <div class="object-name" id="objectName">대기 중</div>
      <div class="message" id="message">
        아직 감지된 물체가 없습니다.
      </div>
    </div>

    <button class="btn connect-btn" onclick="connectArduino()">
      아두이노 연결
    </button>

    <button class="btn start-btn" onclick="startMonitoring()">
      작업 시작
    </button>

    <div class="footer">
      GitHub Pages + Arduino Web Serial
    </div>

  </div>

  <script>

    let port;
    let reader;
    let monitoring = false;

    async function connectArduino() {
      try {

        port = await navigator.serial.requestPort();

        await port.open({ baudRate: 9600 });

        alert('아두이노 연결 성공!');

      } catch (error) {
        alert('연결 실패: ' + error);
      }
    }

    async function startMonitoring() {

      if (!port) {
        alert('먼저 아두이노를 연결하세요!');
        return;
      }

      monitoring = true;

      const textDecoder = new TextDecoderStream();
      const readableStreamClosed = port.readable.pipeTo(textDecoder.writable);
      reader = textDecoder.readable.getReader();

      while (monitoring) {

        const { value, done } = await reader.read();

        if (done) {
          reader.releaseLock();
          break;
        }

        if (value) {

          const data = value.trim();

          console.log('받은 데이터:', data);

          handleSensorData(data);
        }
      }
    }

    function handleSensorData(data) {

      // 예시 데이터 형식
      // bottle,2
      // box,5

      const parts = data.split(',');

      if (parts.length < 2) return;

      const objectName = parts[0];
      const distance = parts[1];

      document.getElementById('distance').innerText = distance + 'm';
      document.getElementById('objectName').innerText = objectName;

      document.getElementById('message').innerText =
        distance + '미터 앞에 ' + objectName + '이(가) 들어옵니다.';

      speak(distance + '미터 앞에 ' + objectName + '이 들어옵니다');
    }

    function speak(text) {

      const speech = new SpeechSynthesisUtterance(text);

      speech.lang = 'ko-KR';
      speech.rate = 1;
      speech.pitch = 1;

      window.speechSynthesis.speak(speech);
    }

  </script>

</body>
</html>
